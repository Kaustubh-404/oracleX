generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Market {
  id                  BigInt   // on-chain market ID
  chain               String   @default("sepolia")
  question            String
  category            String
  resolutionSource    String
  creator             String
  collateral          String
  yesPool             Decimal  @default(0) @db.Decimal(30, 6)
  noPool              Decimal  @default(0) @db.Decimal(30, 6)
  closingTime         DateTime
  settlementDeadline  DateTime
  outcome             Int      @default(0) // 0=UNRESOLVED 1=YES 2=NO 3=INVALID
  settlementRequested Boolean  @default(false)
  aiConfidenceBps     BigInt   @default(0)
  aiReasoning         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  trades  Trade[]

  @@id([id, chain])
  @@map("markets")
}

model Trade {
  id           Int      @id @default(autoincrement())
  marketId     BigInt
  marketChain  String   @default("sepolia")
  wallet       String
  side         String   // "YES" | "NO"
  usdcAmount   Decimal  @db.Decimal(30, 6)
  action       String   // "BUY" | "SELL"
  txHash       String?
  blockNumber  BigInt?
  logIndex     Int?
  createdAt    DateTime @default(now())

  market Market @relation(fields: [marketId, marketChain], references: [id, chain])

  @@unique([txHash, logIndex])
  @@index([marketId, marketChain])
  @@index([wallet])
  @@map("trades")
}

model IndexerState {
  chain     String @id   // "sepolia" | "worldchain-sepolia"
  lastBlock BigInt @default(0)

  @@map("indexer_state")
}

model WorldIdVerification {
  id                Int      @id @default(autoincrement())
  nullifierHash     String
  action            String
  marketId          String?  // present for oraclexbet, null for oraclexcreatemarket
  verificationLevel String
  createdAt         DateTime @default(now())

  // Same human cannot bet twice on the same market
  @@unique([nullifierHash, action, marketId])
  @@map("world_id_verifications")
}
