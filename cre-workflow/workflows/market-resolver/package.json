{
  "name": "oraclex-market-resolver",
  "version": "1.0.0",
  "description": "CRE workflow: resolves OracleX prediction markets via AI + multi-source data",
  "main": "main.ts",
  "scripts": {
    "build": "cre build",
    "simulate": "cre simulation run --non-interactive --verbose",
    "simulate:broadcast": "cre simulation run --broadcast --verbose",
    "secrets:upload": "cre secrets upload --workflow oraclex-market-resolver",
    "secrets:list": "cre secrets list --workflow oraclex-market-resolver",
    "deploy": "cre deploy --workflow oraclex-market-resolver --target sepolia"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.0.7",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
